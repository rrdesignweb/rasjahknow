---
import Social from "./Social.astro";
---

<div
  class="bg-gray-900 text-white w-full flex justify-between items-center py-8"
>
  <div class="container flex md:justify-between:flex-row flex-col items-center">
    <p>©Copyright Ras Jahknow 2011-<span id="year"></span></p>
    <div class="flex gap-4">
      <Social platform="facebook" username="rasjahknowband" />
      <Social platform="instagram" username="rasjahknow" />
      <Social platform="youtube" username="rasjahknow" />
      <Social platform="tiktok" username="@ras.jahknow.band" />
      <Social
        platform="spotify"
        href="https://open.spotify.com/artist/0JHcjMpdGEI19LwIl1ya82"
      />
      <Social platform="bandcamp" href="https://rasjahknow.bandcamp.com/" />
    </div>
  </div>
</div>

<script type="text/javascript">
  const dt = new Date();
  document.getElementById("year").textContent = dt.getUTCFullYear();
</script>
