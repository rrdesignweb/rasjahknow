---
interface Props {
  platform: string;
  username?: string;
  href?: string;
}

const { platform, username, href } = Astro.props;
const socialHref = href ?? `https://www.${platform}.com/${username}`;
---

<a
  class="appearance-none flex justify-center items-center py-2 my-4 px-2 text-white"
  href={socialHref}
  rel="noreferrer"
  target="_blank"
>
  <img
    class="w-8 text-white"
    src={platform === "facebook"
      ? "/facebook.svg"
      : platform === "instagram"
      ? "/instagram.svg"
      : platform === "tiktok"
      ? "/tiktok.svg"
      : platform === "spotify"
      ? "/spotify.svg"
      : platform === "bandcamp"
      ? "/bandcamp.svg"
      : "/youtube.svg"}
    alt={`${platform} icon`}
    loading="lazy"
  />
</a>