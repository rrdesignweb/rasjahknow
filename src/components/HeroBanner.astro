---
interface Props {
    title: string;
    description: string;
    image: string;
    /** Optional wider/taller desktop asset from Contentful (`heroBannerDesktop`). */
    imageDesktop?: string;
}

const { title, description, image, imageDesktop } = Astro.props;
const hasDesktopImage = Boolean(imageDesktop?.length);
---

<div
    class:list={[
        "relative w-full overflow-hidden",
        hasDesktopImage ? "h-72 md:h-96" : "h-96",
    ]}
>
    <div class="absolute inset-0 z-10 w-full">
        {
            hasDesktopImage ? (
                <>
                    <img
                        src={image}
                        class="absolute inset-0 block h-full w-full object-cover object-center md:hidden"
                        alt=""
                    />
                    <img
                        src={imageDesktop}
                        class="absolute inset-0 hidden h-full w-full object-cover object-center md:block"
                        alt=""
                    />
                </>
            ) : (
                <img
                    src={image}
                    class="absolute inset-0 block h-full w-full object-cover object-center"
                    alt=""
                />
            )
        }
    </div>
    <div
        class="absolute left-0 bottom-0 top-0 right-0 z-30 w-full h-full flex justify-center items-center flex-col pt-24 md:pt-24"
    >
        <h1 class="mt-5 text-2xl md:text-3xl text-white font-semibold text-center">
            {title}
        </h1>
        <p class="text-center w-11/12 md:w-4/12 text-white text-[15px] md:text-lg">{description}</p>
    </div>
    <div
        class="absolute bottom-0 left-0 right-0 top-0 z-20 bg-black bg-opacity-40"
    >
    </div>
</div>
