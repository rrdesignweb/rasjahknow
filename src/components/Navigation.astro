---
const currentPath = Astro.url.pathname;

const navLinks = [
    { href: '/', label: 'Home' },
    { href: '/biography', label: 'Biography' },
    { href: '/music', label: 'Music' },
    { href: '/events', label: 'Events' },
    { href: '/gallery', label: 'Gallery' },
    { href: '/video', label: 'Videos' },
    { href: '/contact', label: 'Contact' },
];

const isActive = (href: string) => {
    if (href === '/') {
        return currentPath === '/';
    }
    return currentPath.startsWith(href);
};
---

<div class="flex items-center lg:order-2 lg:hidden">
    <button
        data-mobile-menu-button
        type="button"
        class="inline-flex items-center p-2 ml-1 text-sm text-gray-100 rounded-lg hover:bg-gray-900 focus:outline-none focus:ring-2 focus:ring-gray-600 dark:text-gray-200 dark:hover:bg-gray-100 dark:focus:ring-gray-600"
        aria-controls="mobile-menu-2"
        aria-expanded="false"
    >
        <span class="sr-only">Open main menu</span>
        <span class="mobile-menu-icon" aria-hidden="true">
            <span class="mobile-menu-icon__line"></span>
            <span class="mobile-menu-icon__line"></span>
            <span class="mobile-menu-icon__line"></span>
        </span>
    </button>
</div>
<nav
    data-mobile-menu
    class="mobile-menu justify-between items-center w-full lg:flex lg:w-auto lg:order-1"
    id="mobile-menu-2"
    aria-label="Main Navigation"
>
    <ul
        class="flex pl-0 flex-col mt-4 uppercase font-semibold lg:flex-row lg:space-x-8 lg:mt-0  list-none"
    >
        {navLinks.map((link) => (
            <li>
                <a
                    href={link.href}
                    data-mobile-menu-link
                    class:list={[
                        "block py-2 pr-4 pl-3 lg:p-0 hover:text-red-600",
                        isActive(link.href) ? "text-red-600" : "text-white"
                    ]}
                    aria-current={isActive(link.href) ? "page" : undefined}
                >{link.label}</a>
            </li>
        ))}
    </ul>
</nav>

<style is:inline>
    .mobile-menu {
        overflow: hidden;
        max-height: 0;
        opacity: 0;
        transform: translateY(-12px);
        pointer-events: none;
        transition:
            max-height 0.35s ease,
            opacity 0.25s ease,
            transform 0.35s ease;
    }

    .mobile-menu.is-open {
        max-height: 24rem;
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
    }

    .mobile-menu-icon {
        position: relative;
        display: inline-flex;
        width: 1.5rem;
        height: 1.5rem;
    }

    .mobile-menu-icon__line {
        position: absolute;
        left: 0;
        width: 100%;
        height: 2px;
        background: currentColor;
        border-radius: 9999px;
        transition:
            transform 0.25s ease,
            opacity 0.2s ease,
            top 0.25s ease;
    }

    .mobile-menu-icon__line:nth-child(1) {
        top: 0.3rem;
    }

    .mobile-menu-icon__line:nth-child(2) {
        top: 0.72rem;
    }

    .mobile-menu-icon__line:nth-child(3) {
        top: 1.14rem;
    }

    button[aria-expanded="true"] .mobile-menu-icon__line:nth-child(1) {
        top: 0.72rem;
        transform: rotate(45deg);
    }

    button[aria-expanded="true"] .mobile-menu-icon__line:nth-child(2) {
        opacity: 0;
    }

    button[aria-expanded="true"] .mobile-menu-icon__line:nth-child(3) {
        top: 0.72rem;
        transform: rotate(-45deg);
    }

    @media (min-width: 1024px) {
        .mobile-menu {
            overflow: visible;
            max-height: none;
            opacity: 1;
            transform: none;
            pointer-events: auto;
            transition: none;
        }
    }
</style>

<script is:inline>
    const button = document.querySelector('[data-mobile-menu-button]');
    const menu = document.querySelector('[data-mobile-menu]');
    const menuLinks = document.querySelectorAll('[data-mobile-menu-link]');

    if (button && menu) {
        const setMenuState = (isOpen) => {
            button.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
            menu.classList.toggle('is-open', isOpen);
        };

        const isMenuOpen = () => button.getAttribute('aria-expanded') === 'true';

        setMenuState(false);

        button.addEventListener('click', (event) => {
            event.stopPropagation();
            setMenuState(!isMenuOpen());
        });

        document.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof Node)) return;
            if (button.contains(target) || menu.contains(target)) return;
            if (!isMenuOpen()) return;
            setMenuState(false);
        });

        menuLinks.forEach((link) => {
            link.addEventListener('click', () => setMenuState(false));
        });
    }
</script>