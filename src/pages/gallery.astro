---
import Layout from "../layouts/Layout.astro";
import HeroBanner from "../components/HeroBanner.astro";
import LightboxGallery from "../components/LightboxGallery";
import { contentfulClient } from "../lib/contentful";
import type { GalleryItem } from "../lib/types";
import PressKit from "../components/PressKit.astro";

interface GalleryPage {
  contentTypeId: "1Q9PvrUhy5EYfZ8vXS6lOR";
  fields: {
    title: string;
    subTitle: string;
    heroBanner: {
      fields: {
        file: {
          url: string | undefined;
        };
      };
    };
    content: string;
  };
}

const entry: any = await contentfulClient.getEntry<GalleryPage>(
  "1Q9PvrUhy5EYfZ8vXS6lOR"
);

const entries = await contentfulClient.getEntries<GalleryItem>({
  content_type: "gallery",
});

const { items } = entries;
---

<Layout title="Gallery">
  <HeroBanner
    title={entry?.fields?.title}
    description={entry?.fields?.subTitle}
    image={entry?.fields.heroBanner.fields.file?.url + "?fm=avif"}
  />
  <section class="container w-11/12 md:w-9/12 mx-auto mt-10 mb-6">
    <h3 class="text-2xl font-semibold">View the Gallery</h3>
    <p>{entry?.fields?.content ?? "Browse photos capturing Ras Jahknow on stage, behind the scenes, and on the road."}</p>
  </section>
  <section class="container w-11/12 md:w-9/12 mx-auto my-5">
    <LightboxGallery data={items} client:load />
  </section>
  <PressKit />
</Layout>
